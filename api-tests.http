### NexTrade API Tests
### Base URL: http://localhost:8080

@baseUrl = http://localhost:8080
@authToken = {{loginResponse.response.body.data.accessToken}}

### 1. Register User
# @name registerResponse
POST {{baseUrl}}/api/v1/auth/register
Content-Type: application/json

{
  "email": "admin@nextrade.com",
  "password": "password123",
  "firstName": "Admin",
  "lastName": "User",
  "role": "ADMIN"
}

### 2. Register Customer
POST {{baseUrl}}/api/v1/auth/register
Content-Type: application/json

{
  "email": "customer@nextrade.com",
  "password": "password123",
  "firstName": "John",
  "lastName": "Customer",
  "role": "CUSTOMER"
}

### 3. Register Vendor
POST {{baseUrl}}/api/v1/auth/register
Content-Type: application/json

{
  "email": "vendor@nextrade.com",
  "password": "password123",
  "firstName": "Jane",
  "lastName": "Vendor",
  "role": "VENDOR"
}

### 4. Login
# @name loginResponse
POST {{baseUrl}}/api/v1/auth/login
Content-Type: application/json

{
  "email": "admin@nextrade.com",
  "password": "password123"
}

### 5. Get Profile
GET {{baseUrl}}/api/v1/auth/me
Authorization: Bearer {{authToken}}

### 6. Create Product (Vendor)
POST {{baseUrl}}/api/v1/products
Content-Type: application/json
Authorization: Bearer {{authToken}}

{
  "sku": "LAPTOP-001",
  "name": "Premium Laptop",
  "description": "High-performance laptop with 16GB RAM",
  "categoryId": 1,
  "price": 999.99,
  "stockQuantity": 50,
  "lowStockThreshold": 5
}

### 7. Get Products
GET {{baseUrl}}/api/v1/products?page=0&size=10
Authorization: Bearer {{authToken}}

### 8. Get Product by ID
GET {{baseUrl}}/api/v1/products/1
Authorization: Bearer {{authToken}}

### 9. Create Order
POST {{baseUrl}}/api/v1/orders
Content-Type: application/json
Authorization: Bearer {{authToken}}

{
  "items": [
    {
      "productId": 1,
      "productName": "Premium Laptop",
      "quantity": 1,
      "unitPrice": 999.99
    }
  ],
  "shippingAddress": "123 Main St, New York, NY 10001",
  "notes": "Please handle with care"
}

### 10. Get Orders
GET {{baseUrl}}/api/v1/orders?page=0&size=10
Authorization: Bearer {{authToken}}

### 11. Get Order by ID
GET {{baseUrl}}/api/v1/orders/1
Authorization: Bearer {{authToken}}

### 12. Update Order Status
PUT {{baseUrl}}/api/v1/orders/1/status
Content-Type: application/json
Authorization: Bearer {{authToken}}

{
  "status": "PREPARING",
  "note": "Order is being prepared"
}

### 13. Get Payment for Order
GET {{baseUrl}}/api/v1/payments/1
Authorization: Bearer {{authToken}}

### 14. Get All Transactions
GET {{baseUrl}}/api/v1/payments/transactions
Authorization: Bearer {{authToken}}

### 15. Get Notifications
GET {{baseUrl}}/api/v1/notifications
Authorization: Bearer {{authToken}}

### 16. Get Unread Count
GET {{baseUrl}}/api/v1/notifications/unread-count
Authorization: Bearer {{authToken}}

### 17. Mark Notification as Read
PUT {{baseUrl}}/api/v1/notifications/1/read
Authorization: Bearer {{authToken}}

### 18. Cancel Order
POST {{baseUrl}}/api/v1/orders/1/cancel?reason=Changed%20my%20mind
Authorization: Bearer {{authToken}}

### 19. Adjust Stock
PUT {{baseUrl}}/api/v1/products/1/stock
Content-Type: application/json
Authorization: Bearer {{authToken}}

{
  "quantity": 10,
  "reason": "Restocked"
}

### 20. Refund Payment
POST {{baseUrl}}/api/v1/payments/1/refund
Content-Type: application/json
Authorization: Bearer {{authToken}}

{
  "reason": "Customer requested refund"
}
